<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="tk_insurance_management.ins_dashboard" owl="1">
        <section class="section insurance_dashboard">
            <div class="container">
            <div class="row">
                    <div class="col-md-8">
                        <div class="row">
                            <div class="col-md-12 mt32">
                                <h4 class="tk-primary">Insurance Overview</h4>
                                <hr class="border-primary"/>
                            </div>
                            <div class="col-md-3 mb-4 mt8 mb16" t-on-click="() => this.viewInsurances('all')">
                                <div class="card info-bg p-32">
                                    <div class="card-body info-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/1-total.svg"/>
                                        <h4 class="tk-st-1 info-bg">Total</h4>
                                        <h6 class="tk-st-2 info-bg">
                                            <t t-esc="state.totalInsurances['total_insurance']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 mb-4 mt8 mb16" t-on-click="() => this.viewInsurances('draft')">
                                <div class="card purple-bg p-32">
                                    <div class="card-body purple-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/2-new.svg"/>
                                        <h4 class="tk-st-1 purple-bg">New</h4>
                                        <h6 class="tk-st-2 purple-bg">
                                            <t t-esc="state.totalInsurances['draft_insurance']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 mb-4 mt8 mb16" t-on-click="() => this.viewInsurances('running')">
                                <div class="card warn-bg p-32">
                                    <div class="card-body warn-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/3-running.svg"/>
                                        <h4 class="tk-st-1 warn-bg">Running</h4>
                                        <h6 class="tk-st-2 warn-bg">
                                            <t t-esc="state.totalInsurances['running_insurance']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 mb-4 mt8 mb16" t-on-click="() => this.viewInsurances('expired')">
                                <div class="card terminate-bg p-32">
                                    <div class="card-body terminate-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/4-expire.svg"/>
                                        <h4 class="tk-st-1 terminate-bg">Expired</h4>
                                        <h6 class="tk-st-2 terminate-bg">
                                            <t t-esc="state.totalInsurances['expired_insurance']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                <div class="col-md-4">
                        <div class="row">
                            <div class="col-md-12 mt32">
                                <h4 class="tk-primary">Additional Statistics</h4>
                                <hr class="border-primary"/>
                            </div>
                            <div class="col-md-6 mb-4 mt8 mb16" t-on-click="() => this.viewInsuranceAgents()">
                                <div class="card purple-bg p-32">
                                    <div class="card-body purple-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/5-agent.svg"/>
                                        <h4 class="tk-st-1 purple-bg">Agents</h4>
                                        <h6 class="tk-st-2 purple-bg">
                                            <t t-esc="state.insuranceAgents['res_partner_agent']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4 mt8 mb16" t-on-click="() => this.viewInsuranceCategory()">
                                <div class="card success-bg p-32">
                                    <div class="card-body success-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/6-cate.svg"/>
                                        <h4 class="tk-st-1 success-bg">Categories</h4>
                                        <h6 class="tk-st-2 success-bg">
                                            <t t-esc="state.insuranceCategory['insurance_category']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="row">
                            <div class="col-md-12 mt32">
                                <h4 class="tk-primary">Claim Overview</h4>
                                <hr class="border-primary"/>
                            </div>
                            <div class="col-md-4 mb-4 mt8 mb16" t-on-click="() => this.viewClaims('all')">
                                <div class="card info-bg p-32">
                                    <div class="card-body info-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/7-claim.svg"/>
                                        <h4 class="tk-st-1 info-bg">Total</h4>
                                        <h6 class="tk-st-2 info-bg">
                                            <t t-esc="state.totalClaims['total_claim']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-4 mt8 mb16" t-on-click="() => this.viewClaims('submit')">
                                <div class="card purple-bg p-32">
                                    <div class="card-body purple-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/r.svg"/>
                                        <h4 class="tk-st-1 purple-bg">Registered</h4>
                                        <h6 class="tk-st-2 purple-bg">
                                            <t t-esc="state.totalClaims['submit_claim']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-4 mt8 mb16" t-on-click="() => this.viewClaims('under_review')">
                                <div class="card warn-bg p-32">
                                    <div class="card-body warn-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/8-submit.svg"/>
                                        <h4 class="tk-st-1 warn-bg">In Review</h4>
                                        <h6 class="tk-st-2 warn-bg">
                                            <t t-esc="state.totalClaims['under_review_claim']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-4 mt8 mb16" t-on-click="() => this.viewClaims('approved')">
                                <div class="card success-bg p-32">
                                    <div class="card-body success-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/claim.svg"/>
                                        <h4 class="tk-st-1 success-bg">Approved</h4>
                                        <h6 class="tk-st-2 success-bg">
                                            <t t-esc="state.totalClaims['approved_claim']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-4 mt8 mb16" t-on-click="() => this.viewClaims('not_approved')">
                                <div class="card terminate-bg p-32">
                                    <div class="card-body terminate-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/rejected.svg"/>
                                        <h4 class="ins-not-approve terminate-bg">Rejected</h4>
                                        <h6 class="tk-st-2 terminate-bg">
                                            <t t-esc="state.totalClaims['not_approved_claim']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-4 mt8 mb16" t-on-click="() => this.viewClaims('closed')">
                                <div class="card active-bg p-32">
                                    <div class="card-body active-bg tk-card-body">
                                        <img alt="users" width="40"
                                             src="/tk_insurance_management/static/src/img/dashboard/invoice.svg"/>
                                        <h4 class="tk-st-1 active-bg">Closed</h4>
                                        <h6 class="tk-st-2 active-bg">
                                            <t t-esc="state.totalClaims['closed_claim']"/>
                                        </h6>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="row">
                            <div class="col-md-12 mt32">
                                <h4 class="tk-primary">Top-Ranked Insurance Agents</h4>
                                <hr class="border-primary"/>
                                <div class="tk-os-chart" t-ref="insurance_top_agent"/>
                            </div>
                        </div>
                     </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="tk-primary">Customer’s Gender</h4>
                                <hr class="border-primary"/>
                                <div class="tk-os-chart" t-ref="customer_gender"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="row">
                            <div class="col-md-12">
                                <h4 class="tk-primary">Monthly Revenue from Insurance Invoices</h4>
                                <hr class="border-primary"/>
                                <div class="tk-os-chart" t-ref="invoice_month_graph"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 tk-os-chart">
                        <h4 class="tk-primary">
                            <t t-esc="state.totalInsurances['policy_expiry_remaining_days']"/>
                            days before expiry: Displaying currently running insurance policies set to expire soon.
                        </h4>
                        <hr class="border-primary"/>
                        <div style="max-height: 300px; overflow-y: auto;" class="p-0">
                            <t t-if="state.expiringInsurance.length > 0">
                                <table class="table table-striped tablebg" style="font-size: 14px; text-align: center;">
                                    <thead class="sticky-top bg-primary text-white thead-dark" style="font-size: 16px;">
                                        <tr>
                                            <th>Insurance Number</th>
                                            <th>Policy Holder</th>
                                            <th>Policy Category</th>
                                            <th>Sub Category</th>
                                            <th>Insurance Policy</th>
                                            <th>Policy Time Period</th>
                                            <th>Expiry Date</th>
                                            <th>Remaining Days</th>
                                            <th>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.expiringInsurance" t-as="insurance" t-key="insurance.id">
                                            <tr>
                                                <td scope="row">
                                                    <span class="font-weight-bold" t-esc="insurance.insurance_number"/>
                                                </td>
                                                <td>
                                                    <span class="font-weight-bold" t-esc="insurance.policy_holder"/>
                                                </td>
                                                <td>
                                                    <span class="font-weight-bold" t-esc="insurance.category"/>
                                                </td>
                                                <td>
                                                    <span class="font-weight-bold" t-esc="insurance.sub_category"/>
                                                </td>
                                                <td>
                                                    <span class="font-weight-bold" t-esc="insurance.insurance_policy"/>
                                                </td>
                                                <td>
                                                    <span class="font-weight-bold" t-esc="insurance.time_period"/>
                                                </td>
                                                <td>
                                                    <span class="font-weight-bold" t-esc="insurance.expiry_date"/>
                                                </td>
                                                <td>
                                                    <!-- Highlight red remaining days are less than 30 -->
                                                    <t t-if="insurance.remaining_days &lt; 30">
                                                        <span class="font-weight-bold me-1 text-danger">
                                                            <t t-esc="insurance.remaining_days"/>
                                                            Days
                                                        </span>
                                                    </t>
                                                    <!-- Highlight warning greater than 30 and less than 60 days -->
                                                    <t t-elif="insurance.remaining_days &gt;= 30 and insurance.remaining_days &lt;= 60">
                                                        <span class="font-weight-bold me-1 text-warning">
                                                            <t t-esc="insurance.remaining_days"/>
                                                            Days
                                                        </span>
                                                    </t>
                                                    <!-- Highlight green more than 60 days -->
                                                    <t t-else="">
                                                        <span class="font-weight-bold me-1 text-success">
                                                            <t t-esc="insurance.remaining_days"/>
                                                            Days
                                                        </span>
                                                    </t>
                                                </td>
                                                <td class="text-right">
                                                    <button class="btn btn-primary"
                                                            t-att-data-ins="insurance.id"
                                                            t-on-click="() => this.viewInsurance(insurance.id)"
                                                            style="border-radius: 2px; line-height: 0.8; font-weight: 400; font-size: 0.75rem; padding: 0.25rem 0.5rem;">
                                                        View
                                                    </button>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="alert alert-info" role="alert">
                                    No policies are due to expire soon.
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

            </div>
        </section>
    </t>
</templates>