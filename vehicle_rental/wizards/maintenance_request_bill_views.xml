<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="maintenance_request_bill_form_view" model="ir.ui.view">
            <field name="name">maintenance.request.bill.form.view</field>
            <field name="model">maintenance.request.bill</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="vendor_id" required="1"/>
                        </group>
                        <group>
                            <field name="maintenance_request_id" invisible="1"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Create Bill" name="action_create_vendor_bill" type="object"
                                class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_maintenance_request_bill" model="ir.actions.act_window">
            <field name="name">Maintenance Request Bill</field>
            <field name="res_model">maintenance.request.bill</field>
            <field name="target">new</field>
            <field name="view_id" ref="maintenance_request_bill_form_view"/>
        </record>
    </data>
</odoo>