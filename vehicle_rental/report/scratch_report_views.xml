<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <template id="vehicle_rental_contract_scratch_report_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page-content" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
                            <style type="text/css">
                                :root {
                                --font-family-century-gothic: "Century Gothic";
                                --font-family-arial: "Arial";
                                }
                                <!--Century Gothic-->
                                @font-face {
                                font-family: 'Century Gothic';
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic.eot');
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic.eot?#iefix')
                                format('embedded-opentype'),
                                url('/vehicle_rental/static/src/fonts/CenturyGothic.ttf') format('truetype');
                                font-weight: normal;
                                font-style: normal;
                                font-display: swap;
                                }

                                @font-face {
                                font-family: 'Century Gothic';
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic-Bold.eot');
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic-Bold.eot?#iefix')
                                format('embedded-opentype'),
                                url('/vehicle_rental/static/src/fonts/CenturyGothic-Bold.ttf')
                                format('truetype');
                                font-weight: bold;
                                font-style: normal;
                                font-display: swap;
                                }

                                @font-face {
                                font-family: 'Century Gothic';
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic-BoldItalic.eot');
                                src:
                                url('/vehicle_rental/static/src/fonts/CenturyGothic-BoldItalic.eot?#iefix')
                                format('embedded-opentype'),
                                url('/vehicle_rental/static/src/fonts/CenturyGothic-BoldItalic.ttf')
                                format('truetype');
                                font-weight: bold;
                                font-style: italic;
                                font-display: swap;
                                }

                                @font-face {
                                font-family: 'Century Gothic';
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic-Italic.eot');
                                src: url('/vehicle_rental/static/src/fonts/CenturyGothic-Italic.eot?#iefix')
                                format('embedded-opentype'),
                                url('/vehicle_rental/static/src/fonts/CenturyGothic-Italic.ttf')
                                format('truetype');
                                font-weight: normal;
                                font-style: italic;
                                font-display: swap;
                                }
                                @font-face {
                                font-family: 'Arial';
                                src: url('ArialMT.eot');
                                src: url('ArialMT.eot?#iefix') format('embedded-opentype'),
                                url('/vehicle_rental/static/src/fonts/ArialMT.woff') format('woff'),
                                url('/vehicle_rental/static/src/fonts/ArialMT.ttf') format('truetype');
                                font-weight: normal;
                                font-style: normal;
                                font-display: swap;
                                }
                                .jobcard-table td {
                                padding: 0px;
                                }
                                .label-cell { width: 9%; }
                                .separator { width: 1%; }
                                .value-cell { width: 15%; }
                            </style>
                            <table class="table table-borderless jobcard-table"
                                   style="width: 100%; font-size: 11px; font-family: 'Arial', sans-serif; margin: 0;">
                                <tr style="border-top: 1px solid black;">
                                    <td class="label-cell">
                                        <strong>Reference Number</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.reference_no"/>
                                    </td>

                                    <td class="label-cell">
                                        <strong>Vehicle</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.vehicle_id"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        <strong>Customer</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.customer_id.name"/>
                                    </td>

                                    <td class="label-cell">
                                        <strong>Model</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.vehicle_model_year"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-cell">
                                        <strong>Phone</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.customer_phone"/>
                                    </td>

                                    <td class="label-cell">
                                        <strong>Transmission</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.transmission"/>
                                    </td>
                                </tr>
                                <tr style="border-bottom: 1px solid black;">
                                    <td class="label-cell">
                                        <strong>Email</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.customer_email"/>
                                    </td>

                                    <td class="label-cell">
                                        <strong>Fuel Type</strong>
                                    </td>
                                    <td class="separator">:</td>
                                    <td class="value-cell">
                                        <span t-field="doc.fuel_type"/>
                                    </td>
                                </tr>
                            </table>
                            <table class="table table-bordered" style="width: 100%; margin: 0px; margin-top: 1rem;">
                                <tr>
                                    <td style="text-align: center;">
                                        <t t-if="doc.is_scratch_report">
                                            <t t-if="doc.scratch_image">
                                                <img t-att-src="'data:image/png;base64,%s' % doc.scratch_image.decode('utf-8')"
                                                     style="height: 43rem;"/>
                                            </t>
                                            <t t-else="">
                                                <img t-att-src="'data:image/png;base64,%s' % doc.vehicle_scratch_report_id.avatar.decode('utf-8')"
                                                     style="height: 43rem;"/>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <img src="/vehicle_rental/static/src/img/img.png" style="height: 43rem;"/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                            <p style="page-break-after:always;"/>
                            <table class="table table-borderless"
                                   style="font-size: 11px; width: 100%; font-family: 'Century Gothic' !important; margin: 0px;">
                                <tr>
                                    <td style="padding: 2px; width:100%; font-size: 14px;">
                                        <strong>Terms &amp; Conditions</strong>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 2px; width: 100%;">
                                        <t t-if="doc.rental_terms">
                                            <span t-field="doc.rental_terms"/>
                                        </t>
                                        <t t-else="">
                                            <br/>
                                            <br/>
                                            <br/>
                                            <br/>
                                            <br/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                            <div class="row"
                                 style="text-align: center; padding-top: 5rem; font-family: 'Century Gothic' !important;">
                                <div class="col-3">
                                    <t t-if="doc.signature">
                                        <img t-att-src="image_data_uri(doc.signature)" att="Logo"
                                             style="width: 100px; height: 40px; margin-bottom: -10px;"/>
                                    </t>
                                    <hr style="margin: 0; padding: 0; border: 1px solid #000;"/>
                                    <div style="margin-top: 4px;">
                                        <strong>
                                            Authorized Signature
                                        </strong>
                                    </div>
                                </div>
                                <div class="col-6">
                                </div>
                                <div class="col-3">
                                    <t t-if="doc.customer_signature">
                                        <img t-att-src="image_data_uri(doc.customer_signature)" att="Logo"
                                             style="width: 100px; height: 40px; margin-bottom: -10px;"/>
                                    </t>
                                    <hr style="margin: 0; padding: 0; border: 1px solid #000;"/>
                                    <div style="margin-top: 4px;">
                                        <strong>
                                            Customer Signature
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_rental_scratch_report_template" model="ir.actions.report">
            <field name="name">Scratch Report</field>
            <field name="model">vehicle.contract</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">vehicle_rental.vehicle_rental_contract_scratch_report_template</field>
            <field name="report_file">vehicle_rental.vehicle_rental_contract_scratch_report_template</field>
            <field name="binding_model_id" ref="model_vehicle_contract"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>