<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">

        <!-- ============== Cancellation Policies ============== -->
        <record id="demo_cancel_policy_flexible" model="cancellation.policy">
            <field name="title">Flexible - 24 Hours Free Cancellation</field>
            <field name="terms_and_conditions"><![CDATA[
                <ul>
                    <li>Free cancellation up to 24 hours before pick-up.</li>
                    <li>50% charge if cancelled within 24 hours.</li>
                    <li>No refund after the contract starts.</li>
                </ul>
            ]]></field>
        </record>

        <record id="demo_cancel_policy_standard" model="cancellation.policy">
            <field name="title">Standard - 72 Hours Notice</field>
            <field name="terms_and_conditions"><![CDATA[
                <ul>
                    <li>Free cancellation up to 72 hours before pick-up.</li>
                    <li>30% charge if cancelled within 72 hours.</li>
                    <li>No refund within 24 hours of pick-up.</li>
                </ul>
            ]]></field>
        </record>

        <record id="demo_cancel_policy_strict" model="cancellation.policy">
            <field name="title">Strict - Non Refundable</field>
            <field name="terms_and_conditions"><![CDATA[
                <p>No refund or modification after booking confirmation.</p>
            ]]></field>
        </record>

        <!-- ============== Rental Agreement Terms ============== -->
        <record id="demo_agreement_terms_standard" model="rental.agreement.terms">
            <field name="name">Standard Rental Agreement</field>
            <field name="rental_terms"><![CDATA[
                <h4>Standard Rental Agreement</h4>
                <ol>
                    <li>Vehicle must be returned in the same condition.</li>
                    <li>Driver must hold a valid driving license.</li>
                    <li>Fuel level must match pick-up level on return.</li>
                    <li>Smoking inside the vehicle is strictly prohibited.</li>
                    <li>Renter is responsible for traffic violations.</li>
                </ol>
            ]]></field>
        </record>

        <record id="demo_agreement_terms_corporate" model="rental.agreement.terms">
            <field name="name">Corporate Long-Term Agreement</field>
            <field name="rental_terms"><![CDATA[
                <h4>Corporate Long-Term Rental Terms</h4>
                <ol>
                    <li>Monthly invoicing with NET-30 payment terms.</li>
                    <li>Vehicle replacement guarantee within 24 hours.</li>
                    <li>Free maintenance scheduling included.</li>
                    <li>Insurance coverage with zero deductible.</li>
                </ol>
            ]]></field>
        </record>

        <!-- ============== Maintenance Schedule ============== -->
        <record id="demo_maint_schedule_monthly" model="maintenance.schedule">
            <field name="name">Monthly Check-up</field>
            <field name="maintenance_days">30</field>
        </record>

        <record id="demo_maint_schedule_quarterly" model="maintenance.schedule">
            <field name="name">Quarterly Service</field>
            <field name="maintenance_days">90</field>
        </record>

        <record id="demo_maint_schedule_yearly" model="maintenance.schedule">
            <field name="name">Annual Major Service</field>
            <field name="maintenance_days">365</field>
        </record>

        <!-- ============== Fleet Features ============== -->
        <record id="demo_feature_ac" model="fleet.features">
            <field name="name">Air Conditioning</field>
        </record>
        <record id="demo_feature_bluetooth" model="fleet.features">
            <field name="name">Bluetooth</field>
        </record>
        <record id="demo_feature_gps" model="fleet.features">
            <field name="name">GPS Navigation</field>
        </record>
        <record id="demo_feature_sunroof" model="fleet.features">
            <field name="name">Sunroof</field>
        </record>
        <record id="demo_feature_leather" model="fleet.features">
            <field name="name">Leather Seats</field>
        </record>
        <record id="demo_feature_cruise" model="fleet.features">
            <field name="name">Cruise Control</field>
        </record>
        <record id="demo_feature_camera" model="fleet.features">
            <field name="name">Reverse Camera</field>
        </record>
        <record id="demo_feature_apple_carplay" model="fleet.features">
            <field name="name">Apple CarPlay</field>
        </record>

        <!-- ============== Vehicle Rental Checklists ============== -->
        <record id="demo_checklist_standard" model="vehicle.rental.checklist">
            <field name="name">Standard Pickup &amp; Return Checklist</field>
        </record>

        <record id="demo_checklist_item_1" model="rental.checklist.item">
            <field name="sequence">1</field>
            <field name="name">Exterior Inspection</field>
            <field name="display_type">line_section</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_2" model="rental.checklist.item">
            <field name="sequence">2</field>
            <field name="name">Body scratches / dents</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_3" model="rental.checklist.item">
            <field name="sequence">3</field>
            <field name="name">All tires - condition &amp; pressure</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_4" model="rental.checklist.item">
            <field name="sequence">4</field>
            <field name="name">Headlights / brake lights / signals</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_5" model="rental.checklist.item">
            <field name="sequence">5</field>
            <field name="name">Interior Inspection</field>
            <field name="display_type">line_section</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_6" model="rental.checklist.item">
            <field name="sequence">6</field>
            <field name="name">Seats and floor cleanliness</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_7" model="rental.checklist.item">
            <field name="sequence">7</field>
            <field name="name">Dashboard warning lights</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_8" model="rental.checklist.item">
            <field name="sequence">8</field>
            <field name="name">Fuel level recorded</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>
        <record id="demo_checklist_item_9" model="rental.checklist.item">
            <field name="sequence">9</field>
            <field name="name">Note: Spare key handed over</field>
            <field name="display_type">line_note</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
        </record>

        <!-- ============== Extra Service Products ============== -->
        <record id="demo_service_gps" model="product.product">
            <field name="name">GPS Device Rental</field>
            <field name="type">service</field>
            <field name="list_price">25.0</field>
        </record>
        <record id="demo_service_child_seat" model="product.product">
            <field name="name">Child Safety Seat</field>
            <field name="type">service</field>
            <field name="list_price">15.0</field>
        </record>
        <record id="demo_service_additional_driver" model="product.product">
            <field name="name">Additional Driver</field>
            <field name="type">service</field>
            <field name="list_price">50.0</field>
        </record>
        <record id="demo_service_wifi" model="product.product">
            <field name="name">Mobile Wi-Fi Hotspot</field>
            <field name="type">service</field>
            <field name="list_price">20.0</field>
        </record>
        <record id="demo_service_roadside" model="product.product">
            <field name="name">24/7 Roadside Assistance</field>
            <field name="type">service</field>
            <field name="list_price">30.0</field>
        </record>

        <!-- ============== Maintenance Parts ============== -->
        <record id="demo_part_engine_oil" model="product.product">
            <field name="name">Engine Oil 5W-30 (4L)</field>
            <field name="type">consu</field>
            <field name="list_price">80.0</field>
        </record>
        <record id="demo_part_brake_pads" model="product.product">
            <field name="name">Brake Pads (Set)</field>
            <field name="type">consu</field>
            <field name="list_price">220.0</field>
        </record>
        <record id="demo_part_tires" model="product.product">
            <field name="name">All-Season Tire</field>
            <field name="type">consu</field>
            <field name="list_price">350.0</field>
        </record>

        <!-- ============== Maintenance Services ============== -->
        <record id="demo_service_labor" model="product.product">
            <field name="name">Mechanic Labor (per hour)</field>
            <field name="type">service</field>
            <field name="list_price">120.0</field>
        </record>
        <record id="demo_service_wash" model="product.product">
            <field name="name">Vehicle Wash &amp; Detail</field>
            <field name="type">service</field>
            <field name="list_price">60.0</field>
        </record>

    </data>
</odoo>
