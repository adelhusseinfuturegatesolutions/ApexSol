<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">

        <!-- ============== CRM Leads - Booking Enquiries ============== -->

        <record id="demo_lead_1" model="crm.lead">
            <field name="name">Booking Enquiry - Audi A3 - Weekly</field>
            <field name="type">opportunity</field>
            <field name="partner_id" ref="demo_customer_1"/>
            <field name="contact_name">Ahmed Al-Saleh</field>
            <field name="email_from">ahmed.saleh@example.com</field>
            <field name="phone">+966 50 111 2233</field>
            <field name="vehicle_id" ref="demo_vehicle_audi_a3"/>
            <field name="fleet_price_type">week</field>
            <field name="rent_price">1700.0</field>
            <field name="start_date" eval="(DateTime.now() + relativedelta(days=15)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="end_date" eval="(DateTime.now() + relativedelta(days=22)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="is_website_enquiry">1</field>
            <field name="description">Customer wants Audi A3 for a one-week business trip.</field>
        </record>

        <record id="demo_lead_2" model="crm.lead">
            <field name="name">Booking Enquiry - BMW X5 - Monthly Corporate</field>
            <field name="type">opportunity</field>
            <field name="partner_id" ref="demo_customer_company"/>
            <field name="contact_name">Apex Solutions LLC</field>
            <field name="email_from">contact@apexsol.com</field>
            <field name="phone">+966 11 555 6677</field>
            <field name="vehicle_id" ref="demo_vehicle_bmw_x5"/>
            <field name="fleet_price_type">month</field>
            <field name="rent_price">10500.0</field>
            <field name="start_date" eval="(DateTime.now() + relativedelta(days=30)).strftime('%Y-%m-%d 08:00:00')"/>
            <field name="end_date" eval="(DateTime.now() + relativedelta(days=90)).strftime('%Y-%m-%d 08:00:00')"/>
            <field name="is_website_enquiry">1</field>
            <field name="description">Two-month executive vehicle for company CEO.</field>
        </record>

        <record id="demo_lead_3" model="crm.lead">
            <field name="name">Booking Enquiry - Tesla - Daily</field>
            <field name="type">lead</field>
            <field name="contact_name">Walk-in Customer</field>
            <field name="email_from">walkin@example.com</field>
            <field name="phone">+966 56 777 1122</field>
            <field name="vehicle_id" ref="demo_vehicle_tesla"/>
            <field name="fleet_price_type">day</field>
            <field name="rent_price">380.0</field>
            <field name="start_date" eval="(DateTime.now() + relativedelta(days=5)).strftime('%Y-%m-%d 10:00:00')"/>
            <field name="end_date" eval="(DateTime.now() + relativedelta(days=8)).strftime('%Y-%m-%d 10:00:00')"/>
            <field name="description">Walk-in enquiry for weekend Tesla rental.</field>
        </record>

        <record id="demo_lead_4" model="crm.lead">
            <field name="name">Hourly Rental Enquiry - Camry</field>
            <field name="type">lead</field>
            <field name="partner_id" ref="demo_customer_4"/>
            <field name="contact_name">Layla Al-Najjar</field>
            <field name="email_from">layla.najjar@example.com</field>
            <field name="phone">+962 79 444 5566</field>
            <field name="vehicle_id" ref="demo_vehicle_camry"/>
            <field name="fleet_price_type">hour</field>
            <field name="rent_price">15.0</field>
            <field name="start_date" eval="(DateTime.now() + relativedelta(days=3)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="end_date" eval="(DateTime.now() + relativedelta(days=3)).strftime('%Y-%m-%d 17:00:00')"/>
            <field name="is_website_enquiry">1</field>
            <field name="description">Hourly rental for airport pickup.</field>
        </record>

    </data>
</odoo>
