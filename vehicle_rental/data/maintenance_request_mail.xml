<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <record id="vehicle_maintenance_request_mail_template" model="mail.template">
            <field name="name">Vehicle Maintenance Request Mail Template</field>
            <field name="model_id" ref="vehicle_rental.model_fleet_vehicle"/>
            <field name="subject">New Vehicle Maintenance Request – {{object.name}}</field>
            <field name="email_from">{{object.company_id.email}}</field>
            <field name="partner_to">{{object.manager_id.id}}</field>
            <field name="body_html" type="html">
                <h4>
                    Dear
                    <strong>
                        <t t-out="object.manager_id.name"/>
                    </strong>
                    ,
                </h4>
                <hr style="margin: 0; padding: 0;"/>
                <p>
                    A new maintenance request has been created for the following vehicle:
                </p>
                <hr style="margin: 0; padding: 0;"/>
                <span>
                    <strong>
                        Vehicle Details
                    </strong>
                </span>
                <hr style="margin: 0; padding: 0;"/>
                <table class="table table-bordered" style="width:100%; border-collapse:collapse;">
                    <tr>
                        <td style="padding: 2px;">
                            <strong>Vehicle</strong>
                        </td>
                        <td style="padding: 2px;">
                            <span t-field="object.name"/>
                        </td>
                    </tr>
                    <tr t-if="object.driver_id">
                        <td style="padding: 2px;">
                            <strong>Driver</strong>
                        </td>
                        <td style="padding: 2px;">
                            <span t-field="object.driver_id"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 2px;">
                            <strong>Request Date</strong>
                        </td>
                        <td style="padding: 2px;">
                            <t t-out="object.env.context.get('request_date')"/>
                        </td>
                    </tr>
                    <tr t-if="object.maintenance_schedule_id">
                        <td style="padding: 2px;">
                            <strong>Next Maintenance Schedule</strong>
                        </td>
                        <td style="padding: 2px;">
                            <span t-field="object.maintenance_schedule_id"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 2px;">
                            <strong>Upcoming Maintenance Date</strong>
                        </td>
                        <td style="padding: 2px;">
                            <t t-out="object.env.context.get('upcoming_maintenance_date')"/>
                        </td>
                    </tr>
                </table>
                <hr style="margin: 0; padding: 0;"/>
                <p>
                    Please review the request and schedule the necessary service arrangements.
                </p>
                <hr style="margin: 0; padding: 0;"/>
                <strong>
                    Regards,
                    <br/>
                    <t t-out="object.company_id.name"/>
                </strong>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>