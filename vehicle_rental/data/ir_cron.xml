<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <!--Vehicle Contract Invoice-->
        <record id="vehicle_contract_invoice" model="ir.cron">
            <field name="name">Vehicle Rental: Vehicle Contract Invoice</field>
            <field name="model_id" ref="vehicle_rental.model_vehicle_contract"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_create_rent_payment_invoice()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--Fleet-->
        <record id="ir_cron_generate_missing_fleet_vehicle_access_tokens" model="ir.cron">
            <field name="name">Vehicle Rental: Generate Access Tokens for Fleet Vehicles</field>
            <field name="model_id" ref="vehicle_rental.model_fleet_vehicle"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.generate_fleets_missing_access_tokens()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!--Vehicle Contract-->
        <record id="ir_cron_generate_missing_access_token_vehicle_contract" model="ir.cron">
            <field name="name">Vehicle Rental: Generate Access Tokens for Vehicle Contracts</field>
            <field name="model_id" ref="vehicle_rental.model_vehicle_contract"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.generate_missing_access_token_contract()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!--Schedule Maintenance-->
        <record id="vehicle_schedule_maintenance" model="ir.cron">
            <field name="name">Vehicle Rental: Vehicle Maintenance Schedule</field>
            <field name="model_id" ref="vehicle_rental.model_maintenance_request"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_create_schedule_maintenance()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--Fleet Maintenance-->
        <record id="ir_cron_vehicle_fleet_maintenance_reminder" model="ir.cron">
            <field name="name">Vehicle Maintenance Reminder Cron</field>
            <field name="model_id" ref="vehicle_rental.model_fleet_vehicle"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.cron_send_maintenance_reminder()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>