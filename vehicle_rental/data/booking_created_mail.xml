<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <record id="successful_booking_creation_mail_template" model="mail.template">
            <field name="name">Successful Booking Creation Mail Template</field>
            <field name="model_id" ref="vehicle_rental.model_vehicle_contract"/>
            <field name="subject">Successful Booking Creation – {{ object.reference_no}}</field>
            <field name="email_from">{{object.company_id.email}}</field>
            <field name="partner_to">{{object.customer_id.id}}</field>
            <field name="body_html" type="html">
                <h4>
                    Dear
                    <strong>
                        <t t-out="object.customer_id.name"/>
                    </strong>
                    ,
                </h4>
                <hr style="margin: 0; padding: 0;"/>
                <p>
                    Your vehicle rental booking has been successfully recorded.
                </p>
                <p>
                    Reference Number:
                    <strong>
                        <t t-out="object.reference_no"/>
                    </strong>
                </p>
                <p>
                    You will receive further instructions regarding pickup and documentation shortly.
                </p>
                <p>
                    Thank you for your trust in our services.
                </p>
                <hr style="margin: 0; padding: 0;"/>
                <strong>
                    Regards,
                    <br/>
                    <t t-out="object.company_id.name"/>
                </strong>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
