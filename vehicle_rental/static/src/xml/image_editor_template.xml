<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="vehicle_rental.ImageEditor">
        <div class="o_image_editor_container">
            <canvas t-ref="canvas" style="border:1px solid #ccc; width: 100%; height: 70vh;">
            </canvas>
            <!-- Enhanced Tools Section -->
            <div class="toolbar-container bg-light p-2 border-top">
                <div class="d-flex flex-wrap gap-2 justify-content-center align-items-center" style="margin-left: 5px;">
                    <!-- Color Picker -->
                    <input type="color" id="colorPicker" value="#ff0000"
                           style="width:30px;margin-right: 10px;margin-top: 3px;height: 30px;padding: 0;"/>

                    <!-- Drawing Tools -->
                    <div class="d-flex gap-3 ms-auto">
                        <button class="editor-btn"
                                t-on-click="() => this.selectTool('select')" title="Select/Move Objects">
                            <span class="editor-icon">
                                <i class="fa fa-mouse-pointer">
                                </i>
                            </span>
                            <span>Select</span>
                        </button>
                        <button class="editor-btn" t-on-click="() => this.selectTool('text')" title="Add Text">
                            <span class="editor-icon">
                                <i class="fa fa-font">
                                </i>
                            </span>
                            <span>Text</span>
                        </button>
                        <button class="editor-btn" t-on-click="() => this.selectTool('draw')" title="Free Drawing">
                            <span class="editor-icon">
                                <i class="fa fa-pencil">
                                </i>
                            </span>
                            <span>Draw</span>
                        </button>
                        <button class="editor-btn" t-on-click="() => this.selectTool('rectangle')" title="Add Rectangle">
                            <span class="editor-icon">
                                <i class="fa fa-square-o">
                                </i>
                            </span>
                            <span>Shape</span>
                        </button>
                        <button class="editor-btn" t-on-click="() => this.selectTool('arrow')" title="Add Arrow">
                            <span class="editor-icon">
                                <i class="fa fa-arrow-right">
                                </i>
                            </span>
                            <span>Arrow</span>
                        </button>
                    </div>

                    <!-- Delete -->
                    <button class="editor-btn btn-outline-danger ms-auto"
                            t-on-click="deleteSelected" title="Delete Selected">
                        <span class="delete-editor-icon">
                            <i class="fa fa-trash">
                            </i>
                        </span>
                        <span class="text-danger">Delete</span>
                    </button>
                </div>
            </div>

            <!-- Enhanced Footer -->
            <div class="modal-footer d-flex justify-content-center bg-light border-top">
                <div class="btn-group" role="group">
                    <button style="margin-right: 10px;" class="btn btn-sm btn-outline-secondary"
                            t-on-click="discardChanges">
                        <i class="fa fa-times me-1">
                        </i>Cancel
                    </button>
                    <button class="btn btn-sm btn-success" t-on-click="saveImage">
                        <i class="fa fa-save me-1">
                        </i>Save
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
