<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_vehicle_rental" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.vehicle.rental</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Vehicles Rental" string="Vehicles Rental" name="vehicle_rental">
                        <!-- Terms & Policies Block -->
                        <block title="Links of Terms and Policies" id="vehicle_rental_terms_policy">
                            <setting help="Enter link to see terms &amp; conditions">
                                <field name="terms_conditions_link" class="ms-2 oe_inline"
                                       string="Terms &amp; Conditions"
                                       style="width: 10%; min-width: 4rem;"/>
                            </setting>
                            <setting help="Enter link to see privacy policies">
                                <field name="privacy_policy_link" class="ms-2 oe_inline"
                                       style="width: 10%; min-width: 4rem;"/>
                            </setting>
                        </block>

                        <!--Other Details-->
                        <block title="Other">
                            <setting help="Number of items or vehicles to display per page in paginated views.">
                                <field name="pagination_item_per_page"/>
                            </setting>
                        </block>

                        <!-- Default CRM Assignment Block -->
                        <block title="Default CRM Assignment" id="vehicle_rental_crm_assignment">
                            <setting help="Select the default salesperson for rental booking enquiries.">
                                <field name="salesperson_id" widget="many2one_avatar_user"
                                       domain="[('share', '=', False)]" options="{'no_create': True}"/>
                            </setting>

                            <setting help="Select the default sales team for rental booking enquiries.">
                                <field name="sale_team_id" options="{'no_create': True}"/>
                            </setting>
                        </block>

                        <!--Vehicle Maintenance Settings-->
                        <block title="Vehicle Maintenance Settings">
                            <setting id="maintenance_reminder_days_setting" string="Maintenance Reminder Before (Days)"
                                     help="Number of days before the maintenance due date to send reminder email.">
                                <field name="maintenance_reminder_days"/>
                            </setting>
                        </block>

                        <block title="FleetOS Dashboard Theme">
                            <setting string="Theme Accent Color"
                                     help="Enter a hex color code for the FleetOS dashboard primary color. Choose from the presets below or type any hex value.">
                                <div class="d-flex flex-column gap-2 ms-2">
                                    <field name="dashboard_theme_color"
                                           class="oe_inline"
                                           style="width:120px;"/>
                                    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;">
                                        <!-- 10 predefined color swatches -->
                                        <span title="Ocean Blue (#2563eb)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#2563eb;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input,div[name=dashboard_theme_color] input').value='#2563eb'"/>
                                        <span title="Royal Violet (#7c3aed)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#7c3aed;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#7c3aed'"/>
                                        <span title="Cyan Teal (#0891b2)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#0891b2;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#0891b2'"/>
                                        <span title="Emerald Green (#059669)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#059669;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#059669'"/>
                                        <span title="Crimson Red (#dc2626)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#dc2626;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#dc2626'"/>
                                        <span title="Burnt Orange (#ea580c)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#ea580c;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#ea580c'"/>
                                        <span title="Amber Gold (#d97706)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#d97706;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#d97706'"/>
                                        <span title="Rose Pink (#db2777)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#db2777;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#db2777'"/>
                                        <span title="Slate Dark (#0f172a)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#0f172a;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#0f172a'"/>
                                        <span title="Cool Gray (#374151)"
                                              style="display:inline-block;width:24px;height:24px;border-radius:6px;background:#374151;cursor:pointer;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.2);"
                                              onclick="this.closest('.o_setting_box').querySelector('input').value='#374151'"/>
                                    </div>
                                    <small style="color:#6b7280;font-size:11px;">Click a swatch or type hex code (e.g.
                                        #2563eb). Save settings to apply.
                                    </small>
                                </div>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
