<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="rental_contract_scratch_customer_sign_template" name="Scratch Report Approval Template">
        <t t-call="website.layout">
            <div class="container py-5" style="max-width: 750px;">
                <!--Header Section-->
                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="letter-spacing: 0.5px; color:#2E7D32;">
                        Scratch Report Approval
                    </h2>
                    <div style="width:120px; height:4px; background:#4CAF50; margin:10px auto; border-radius:10px;">
                    </div>
                </div>
                <!--Message-->
                <p class="fs-5 mb-4">
                    Hello
                    <strong class="text-dark">
                        <t t-out="contracts.customer_id.name"/>
                    </strong>
                    ,
                    please review the scratch report below and provide your approval by signing.
                </p>
                <!--PDF Preview-->
                <div class="rounded shadow-sm mb-4 border">
                    <embed t-attf-src="/vehicle-rental/protocol-form/#{contracts.access_token}/Vehicle scratch protocol form"
                           width="100%" height="600px" type="application/pdf" style="border-radius: 6px;"/>
                </div>
                <!--Sign Button-->
                <div class="text-center">
                    <a role="button" class="btn btn-success px-4 py-2 fs-5 shadow-sm"
                       t-if="not contracts.customer_signed_date" data-bs-toggle="modal"
                       data-bs-target="#rentContractScratchLabel"><i class="fa fa-pen me-2"/>Accept &amp; Sign Report
                    </a>
                </div>
                <!--Signature Model-->
                <div class="modal fade" id="rentContractScratchLabel" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <form id="accept" method="POST" t-att-data-inspe-record-id="contracts.id"
                              t-att-data-token="contracts.access_token"
                              class="js_accept_json modal-content js_website_submit_form"
                              enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <!--Model Header-->
                            <header class="modal-header p-2">
                                <h4 class="modal-title">Validate Scratch Report</h4>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"/>
                            </header>
                            <!--Model Body-->
                            <main class="modal-body">
                                <p class="text-muted mb-1">
                                    By signing this scratch report, I confirm that the details have been reviewed and
                                    accepted.
                                </p>
                                <ul class="list-unstyled mb-2">
                                    <li class="mb-2">
                                        <strong>Accepted on behalf of:</strong>
                                        <span class="ms-1 text-dark">
                                            <t t-out="contracts.customer_id.name"/>
                                        </span>
                                    </li>
                                </ul>
                                <!--Signature Widget-->
                                <t t-call="portal.signature_form">
                                    <t t-set="call_url"
                                       t-value="'/vehicle-rental/scratch/' + contracts.access_token + '/accept'"/>
                                    <t t-set="default_name" t-value="contracts.customer_id.name"/>
                                </t>
                            </main>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
