<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="maintenance_schedule_form_view" model="ir.ui.view">
            <field name="name">maintenance.schedule.form.view</field>
            <field name="model">maintenance.schedule</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="e.g. 30 Days"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="maintenance_days"/>
                            </group>
                            <group>
                                <field name="company_id" required="1"
                                       options="{'no_create': True, 'no_create_edit': True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="maintenance_schedule_tree_view" model="ir.ui.view">
            <field name="name">maintenance.schedule.tree.view</field>
            <field name="model">maintenance.schedule</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="maintenance_days"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>
        <record id="maintenance_schedule_search_view" model="ir.ui.view">
            <field name="name">maintenance.schedule.search.view</field>
            <field name="model">maintenance.schedule</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="maintenance_days"/>
                </search>
            </field>
        </record>
        <record id="action_maintenance_schedule" model="ir.actions.act_window">
            <field name="name">Maintenance Schedules</field>
            <field name="res_model">maintenance.schedule</field>
            <field name="view_mode">list,form,search</field>
        </record>
    </data>
</odoo>