<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="booking_enquiry_crm_lead_inherit_form_view" model="ir.ui.view">
            <field name="name">booking.enquiry.crm.lead.inherit.form.view</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <header>
                    <button string="Create Contract" name="%(action_lead_rental_contract)d" type="action"
                            class="oe_highlight"
                            invisible="type != 'opportunity' or probability &lt; 100 or contract_id != False"/>
                </header>
                <xpath expr="//field[@name='team_id']" position="after">
                    <field name="access_token" invisible="1"/>
                </xpath>
                <xpath expr="//notebook/page[1]" position="after">
                    <page name="lead_booking_enquiry" string="Booking Enquiry">
                        <separator string="Booking Enquiry Details" name="lead_booking_enquiry_details"/>
                        <group>
                            <group>
                                <field name="vehicle_ids" invisible="1"/>
                                <field name="vehicle_id" options="{'no_quick_create': True}"
                                       readonly="is_website_enquiry != False"/>
                                <field name="category_id"/>
                                <field name="seats"/>
                            </group>
                            <group>
                                <field name="start_date"
                                       readonly="is_website_enquiry != False or contract_id != False"/>
                                <field name="end_date" readonly="is_website_enquiry != False or contract_id != False"/>
                                <field name="contract_id" invisible="contract_id == False" readonly="1"/>
                                <field name="is_website_enquiry" invisible="1"/>
                            </group>
                        </group>
                        <separator string="Pricing Details" name="lead_vehicle_pricing_details"/>
                        <group>
                            <group>
                                <field name="rent_price"
                                       readonly="is_website_enquiry != False or contract_id != False"/>
                                <field name="fleet_renting_days"/>

                                <field name="rental_duration" invisible="fleet_price_type != 'hour'"
                                       string="Total Hours"/>
                                <field name="rental_duration" invisible="fleet_price_type != 'week'"
                                       string="Total Weeks"/>
                                <field name="rental_duration" invisible="fleet_price_type != 'month'"
                                       string="Total Months"/>
                                <field name="rental_duration" invisible="fleet_price_type != 'year'"
                                       string="Total Years"/>
                            </group>
                            <group>
                                <field name="fleet_price_type"
                                       readonly="is_website_enquiry != False or contract_id != False"/>
                                <field name="total_price"/>
                                <field name="company_id" invisible="1"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <record id='booking_enquiry_crm_lead_inherit_list_view' model='ir.ui.view'>
            <field name="name">booking.enquiry.crm.lead.inherit.list.view</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="default_order">create_date desc</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
