        <!-- ============== Vehicle Contract 1: In Progress - Daily Rental ============== -->
        <record id="demo_contract_1" model="vehicle.contract">
            <field name="vehicle_id" ref="demo_vehicle_audi_a3"/>
            <field name="license_plate">RUH-2002</field>
            <field name="last_odometer">28000</field>
            <field name="odometer_unit">kilometers</field>
            <field name="fuel_type">gasoline</field>
            <field name="transmission">automatic</field>
            <field name="model_year">2023</field>
            <field name="is_driver_required">1</field>
            <field name="driver_id" ref="demo_driver_partner_1"/>
            <field name="driver_charge_type">excluding</field>
            <field name="driver_charge">120.0</field>
            <field name="customer_id" ref="demo_customer_1"/>
            <field name="customer_phone">+966 50 111 2233</field>
            <field name="customer_email">ahmed.saleh@example.com</field>
            <field name="rent_type">days</field>
            <field name="rent">280.0</field>
            <field name="start_date" eval="(DateTime.now() - relativedelta(days=2)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="end_date" eval="(DateTime.now() + relativedelta(days=5)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="pick_up_street">King Fahd Road</field>
            <field name="pick_up_city">Riyadh</field>
            <field name="pick_up_zip">11564</field>
            <field name="drop_off_street">King Fahd Road</field>
            <field name="drop_off_city">Riyadh</field>
            <field name="drop_off_zip">11564</field>
            <field name="cancellation_policy_id" ref="demo_cancel_policy_standard"/>
            <field name="rental_agreement_terms_id" ref="demo_agreement_terms_standard"/>
            <field name="payment_type">full_payment</field>
            <field name="if_any_deposit">1</field>
            <field name="deposit">2000.0</field>
            <field name="is_any_extra_charges">1</field>
            <field name="extra_charge">75.0</field>
            <field name="vehicle_rental_checklist_id" ref="demo_checklist_standard"/>
            <field name="status">b_in_progress</field>
            <field name="description"><![CDATA[<p>Business trip rental - Riyadh.</p>]]></field>
        </record>

        <record id="demo_contract_1_extra_1" model="extra.service">
            <field name="product_id" ref="demo_service_gps"/>
            <field name="description">GPS device for navigation</field>
            <field name="product_qty">1</field>
            <field name="amount">25.0</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>
        <record id="demo_contract_1_extra_2" model="extra.service">
            <field name="product_id" ref="demo_service_wifi"/>
            <field name="description">Mobile Wi-Fi for trip</field>
            <field name="product_qty">1</field>
            <field name="amount">20.0</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>

        <record id="demo_contract_1_insurance" model="insurance.policy">
            <field name="policy_number">INS-2024-1001</field>
            <field name="policy_name">Comprehensive Coverage</field>
            <field name="description">Full coverage including collision, theft, and third-party.</field>
            <field name="policy_amount">350.0</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>

        <record id="demo_contract_1_payment_1" model="vehicle.payment.option">
            <field name="name">Full Payment - Contract 1</field>
            <field name="payment_date" eval="DateTime.now().strftime('%Y-%m-%d')"/>
            <field name="payment_amount">1960.0</field>
            <field name="invoice_item_id" ref="vehicle_rent_charge"/>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>

        <record id="demo_contract_1_checklist_1" model="rental.contract.checklist">
            <field name="sequence">1</field>
            <field name="name">Pickup Inspection</field>
            <field name="display_type">line_section</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>
        <record id="demo_contract_1_checklist_2" model="rental.contract.checklist">
            <field name="sequence">2</field>
            <field name="name">Body condition verified</field>
            <field name="is_checkin_item">1</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>
        <record id="demo_contract_1_checklist_3" model="rental.contract.checklist">
            <field name="sequence">3</field>
            <field name="name">Fuel: Full tank</field>
            <field name="is_checkin_item">1</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>
        <record id="demo_contract_1_checklist_4" model="rental.contract.checklist">
            <field name="sequence">4</field>
            <field name="name">Spare key handed</field>
            <field name="is_checkin_item">1</field>
            <field name="vehicle_contract_id" ref="demo_contract_1"/>
        </record>

