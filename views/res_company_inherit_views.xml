<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="res_insurance_company_inherit_form_view" model="ir.ui.view">
            <field name="name">res.insurance.company.inherit.form.view</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name="is_displayed_on_ins_website"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
