<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="insurance_nominee_view_form" model="ir.ui.view">
            <field name="name">insurance.nominee.view.form</field>
            <field name="model">insurance.nominee</field>
            <field name="arch" type="xml">
                <form class="tk_insurance_form">
                <header>
                <button name="%(action_insurance_claim)d" string="Create Claim" type="action" class="oe_highlight"
                                groups="tk_insurance_management.insurance_manager"
                                invisible="nominee_status == 'inactive'"/>
                <button name="action_set_inactive" type="object" string="Deactivate"
                        class="btn btn-danger"
                        invisible="nominee_status == 'inactive'"
                        confirm="Deactivate this nominee? If this is an employee, all their family members will also be deactivated."
                        groups="tk_insurance_management.insurance_manager"/>
                <button name="action_set_active" type="object" string="Activate"
                        class="btn btn-success"
                        invisible="nominee_status == 'active'"
                        groups="tk_insurance_management.insurance_manager"/>
                <button name="action_create_subscription_invoice" type="object"
                        string="Issue Subscription Invoice"
                        class="btn btn-secondary"
                        invisible="insurance_state != 'running' or nominee_status == 'inactive' or subscription_state == 'subscribed'"
                        groups="tk_insurance_management.insurance_manager"/>
                <field name="nominee_status" widget="badge"
                       decoration-success="nominee_status == 'active'"
                       decoration-danger="nominee_status == 'inactive'"/>
                <field name="subscription_state" widget="badge"
                       decoration-success="subscription_state == 'subscribed'"
                       decoration-muted="subscription_state == 'pending'"/>
                </header>
                    <sheet>
                    <div class="oe_button_box" name="button_box">
                       <button class="oe_stat_button" type="object" name="action_insured_nominee_claim"
                                    icon="fa-bars">
                                <field string="Claims" name="claims_count" widget="statinfo"/>
                            </button>
                       <button class="oe_stat_button" type="object" name="action_open_subscription_invoice"
                                icon="fa-file-text-o" invisible="not subscription_invoice_id">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Subscription</span>
                                    <span class="o_stat_text">Invoice</span>
                                </div>
                            </button>
                       <field name="subscription_invoice_id" invisible="1"/>
                    </div>

                    <!-- Add this block for the image and basic info -->
                    <div class="oe_avatar">
                        <field name="image_1920" widget="image"/>
                    </div>
                        <div class="tk_policy_summary" invisible="not insurance_information_id">
                            <div class="tk_summary_item">
                                <i class="fa fa-shield"/>
                                <div>
                                    <div class="tk_summary_label">Remaining Coverage</div>
                                    <div class="tk_summary_value">
                                        <field name="remaining_consumption" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="tk_summary_item">
                                <i class="fa fa-bars"/>
                                <div>
                                    <div class="tk_summary_label">Approved Claims</div>
                                    <div class="tk_summary_value">
                                        <field name="approved_claims_count" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="tk_summary_item">
                                <i class="fa fa-money"/>
                                <div>
                                    <div class="tk_summary_label">Last Claim</div>
                                    <div class="tk_summary_value">
                                        <field name="last_claim_amount" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <field name="sum_assured" invisible="1"/>
                            <field name="total_claimed" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="insurance_information_id" invisible="1"/>
                        </div>
                        <div class="tk_section_header tk_header_policy"
                             invisible="not insurance_information_id">
                            <i class="fa fa-file-text-o"/>
                            <span>Policy Details</span>
                        </div>
                        <group invisible="not insurance_information_id">
                            <group>
                                <field name="insurance_information_id" string="Policy" readonly="1"/>
                                <field name="insurance_number" readonly="1"/>
                                <field name="insurance_state" widget="badge"
                                       decoration-success="insurance_state == 'running'"
                                       decoration-info="insurance_state == 'confirmed'"
                                       decoration-warning="insurance_state == 'renew'"
                                       decoration-danger="insurance_state in ('expired','cancel')"/>
                            </group>
                            <group>
                                <field name="issue_date" readonly="1"/>
                                <field name="expiry_date" readonly="1"/>
                                <field name="sum_assured" readonly="1"/>
                            </group>
                        </group>
                        <div class="tk_section_header tk_header_holder">
                            <i class="fa fa-id-badge"/>
                            <span>Nominee Details</span>
                        </div>
                        <group>
                            <group>
                                <label for="name"/>
                                <h3>
                                    <field name="name" required="1"/>
                                </h3>
                                <field name="nominee_id" required="1"/>
                                <field name="policy_holder_id"/>
                                <field name="relation_type" required="1"/>
                                <field name="parent_nominee_id"
                                       options="{'no_create': True}"
                                       invisible="relation_type in ('Employee-Male','Employee-Female',False)"/>
                                <field name="insured_gender" required="1"/>
                                <field name="insured_blood_group"/>
                            </group>
                            <group>
                                <label for="nominee_dob" string="Date of Birth"/>
                                <div class="address_format">
                                    <field name="nominee_dob" style="width: auto" required="1"/>
                                    <strong>&#160;Age</strong>
                                    <field name="nominee_age" style="width: auto; margin-left: 5px;"/>
                                </div>
                                <field name="addition_date" required="1"/>
                                <field name="subscription_amount" readonly="1"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="insured_heights"/>
                                <field name="insured_weights"/>
                                <field name="insured_birthmarks"/>
                            </group>
                            <group string="Policy Details" invisible="1">
                                <field name="insurance_category_id"/>
                                <field name="insurance_sub_category_id"/>
                                <field name="insurance_policy_id"/>
                                <field name="policy_price_list_id"/>
                                <field name="policy_provider_cmp_id"/>
                                <field name="issue_date"/>
                                <field name="expiry_date"/>
                            </group>
                        </group>
                        <notebook class="tk_insurance_notebook">
                            <page string="Medical History">
                                <field name="medical_history_ids" >
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="disease_year"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Family Members" invisible="parent_nominee_id != False">
                                <field name="family_member_ids">
                                    <list editable="bottom">
                                        <field name="nominee_id" required="1"/>
                                        <field name="name" required="1"/>
                                        <field name="relation_type" required="1"/>
                                        <field name="insured_gender" required="1"/>
                                        <field name="nominee_dob" required="1"/>
                                        <field name="addition_date" required="1"/>
                                        <field name="insured_blood_group"/>
                                        <field name="subscription_amount" sum="Total"/>
                                        <field name="currency_id" column_invisible="True"/>
                                        <field name="amount_factor" optional="hide"/>
                                    </list>
                                </field>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="insurance_nominee_view_list" model="ir.ui.view">
            <field name="name">insurance.nominee.view.list</field>
            <field name="model">insurance.nominee</field>
            <field name="arch" type="xml">
                <list default_order="parent_nominee_id asc, id asc"
                      decoration-danger="nominee_status == 'inactive'">
                    <field name="parent_nominee_id" string="Main Employee" optional="show"/>
                    <field name="name"/>
                    <field name="nominee_id"/>
                    <field name="relation_type"/>
                    <field name="insured_gender"/>
                    <field name="nominee_status" widget="badge"
                           decoration-success="nominee_status == 'active'"
                           decoration-danger="nominee_status == 'inactive'"/>
                    <field name="nominee_dob"/>
                    <field name="nominee_age"/>
                </list>
            </field>
        </record>

        <record id="insurance_nominee_view_search" model="ir.ui.view">
            <field name="name">insurance.nominee.view.search</field>
            <field name="model">insurance.nominee</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="nominee_id"/>
                    <field name="parent_nominee_id" string="Main Employee"/>
                    <filter name="employees_only" string="Employees Only"
                            domain="[('parent_nominee_id','=',False)]"/>
                    <filter name="family_only" string="Family Members"
                            domain="[('parent_nominee_id','!=',False)]"/>
                    <separator/>
                    <filter name="active_only" string="Active Only"
                            domain="[('active','=',True)]"/>
                    <filter name="inactive_only" string="Inactive Only"
                            domain="[('active','=',False)]"/>
                    <separator/>
                    <filter name="group_main_employee" string="Main Employee"
                            context="{'group_by': 'parent_nominee_id'}"/>
                    <filter name="group_relation" string="Relationship"
                            context="{'group_by': 'relation_type'}"/>
                </search>
            </field>
        </record>

        <record id="action_insurance_nominee" model="ir.actions.act_window">
            <field name="name">Nominee</field>
            <field name="res_model">insurance.nominee</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="insurance_nominee_view_search"/>
            <field name="context">{'search_default_group_main_employee': 1, 'active_test': False}</field>
        </record>

        <!-- Insurance Nominee Relation-->
        <record id="insurance_nominee_relation_list_view" model="ir.ui.view">
            <field name="name">insurance.nominee.relation.list.view</field>
            <field name="model">insurance.nominee.relation</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name" required="1"/>
                </list>
            </field>
        </record>
        <record id="action_insurance_nominee_relation" model="ir.actions.act_window">
            <field name="name">Nominee Relations</field>
            <field name="res_model">insurance.nominee.relation</field>
            <field name="view_mode">list</field>
        </record>
    </data>
</odoo>