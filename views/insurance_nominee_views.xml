<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="insurance_nominee_view_form" model="ir.ui.view">
            <field name="name">insurance.nominee.view.form</field>
            <field name="model">insurance.nominee</field>
            <field name="arch" type="xml">
                <form class="tk_insurance_form">
                <header>
                <button name="%(action_insurance_claim)d" string="Create Claim" type="action" class="oe_highlight"
                                groups="tk_insurance_management.insurance_manager"/>
                </header>
                    <sheet>
                    <div class="oe_button_box" name="button_box">
                       <button class="oe_stat_button" type="object" name="action_insured_nominee_claim"
                                    icon="fa-bars">
                                <field string="Claims" name="claims_count" widget="statinfo"/>
                            </button>
                    </div>

                    <!-- Add this block for the image and basic info -->
                    <div class="oe_avatar">
                        <field name="image_1920" widget="image"/>
                    </div>
                        <div class="tk_section_header tk_header_holder">
                            <i class="fa fa-id-badge"/>
                            <span>Nominee Details</span>
                        </div>
                        <group>
                            <group>
                                <label for="name"/>
                                <h3>
                                    <field name="name"/>
                                </h3>
                                <field name="nominee_id" />
                                <field name="policy_holder_id"/>



                            </group>
                            <group>
                                <label for="nominee_dob" string="Date of Birth"/>
                                <div class="address_format">
                                    <field name="nominee_dob" style="width: auto"/>
                                    <strong>&#160;Age</strong>
                                    <field name="nominee_age" style="width: auto; margin-left: 5px;"/>
                                </div>
                               

                            </group>
                        </group>
                        <div class="tk_section_header tk_header_insured">
                            <i class="fa fa-heartbeat"/>
                            <span>Personal &amp; Medical Info</span>
                        </div>
                        <group>
                            <group>
                                <field name="relation_type"/>
                                <field name="parent_nominee_id"
                                       options="{'no_create': True}"
                                       invisible="relation_type in ('Employee-Male','Employee-Female',False)"/>
                                <field name="insured_gender"/>
                                <field name="insured_blood_group"/>
                                <field name="insured_marital_status"/>
                            </group>
                            <group>
                                <field name="insured_heights"/>
                                <field name="insured_weights"/>
                                <field name="insured_birthmarks"/>
                            </group>
                            <group string="Policy Details" invisible="1">
                                        <field name="insurance_category_id"/>
                                        <field name="insurance_sub_category_id"/>
                                        <field name="insurance_policy_id"/>
                                        <field name="policy_price_list_id"/>
                                        <field name="policy_provider_cmp_id"/>
                                        <field name="issue_date"/>
                                        <field name="expiry_date"/>
                            </group>
                        </group>
                        <notebook class="tk_insurance_notebook">
                            <page string="Medical History">
                                <field name="medical_history_ids" >
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="disease_year"/>
                                        <field name="notes"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Family Members" invisible="parent_nominee_id != False">
                                <field name="family_member_ids">
                                    <list editable="bottom">
                                        <field name="nominee_id"/>
                                        <field name="name"/>
                                        <field name="relation_type"/>
                                        <field name="insured_gender"/>
                                        <field name="nominee_dob"/>
                                        <field name="insured_blood_group"/>
                                        <field name="amount_factor"/>
                                    </list>
                                </field>
                            </page>

                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="insurance_nominee_view_list" model="ir.ui.view">
            <field name="name">insurance.nominee.view.list</field>
            <field name="model">insurance.nominee</field>
            <field name="arch" type="xml">
                <list default_order="parent_nominee_id asc, id asc">
                    <field name="parent_nominee_id" string="Main Employee" optional="show"/>
                    <field name="name"/>
                    <field name="nominee_id"/>
                    <field name="relation_type"/>
                    <field name="insured_gender"/>
                    <field name="nominee_dob"/>
                    <field name="nominee_age"/>
                </list>
            </field>
        </record>

        <record id="insurance_nominee_view_search" model="ir.ui.view">
            <field name="name">insurance.nominee.view.search</field>
            <field name="model">insurance.nominee</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="nominee_id"/>
                    <field name="parent_nominee_id" string="Main Employee"/>
                    <filter name="employees_only" string="Employees Only"
                            domain="[('parent_nominee_id','=',False)]"/>
                    <filter name="family_only" string="Family Members"
                            domain="[('parent_nominee_id','!=',False)]"/>
                    <group expand="1" string="Group By">
                        <filter name="group_main_employee" string="Main Employee"
                                context="{'group_by': 'parent_nominee_id'}"/>
                        <filter name="group_relation" string="Relationship"
                                context="{'group_by': 'relation_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_insurance_nominee" model="ir.actions.act_window">
            <field name="name">Nominee</field>
            <field name="res_model">insurance.nominee</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="insurance_nominee_view_search"/>
            <field name="context">{'search_default_group_main_employee': 1}</field>
        </record>

        <!-- Insurance Nominee Relation-->
        <record id="insurance_nominee_relation_list_view" model="ir.ui.view">
            <field name="name">insurance.nominee.relation.list.view</field>
            <field name="model">insurance.nominee.relation</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name" required="1"/>
                </list>
            </field>
        </record>
        <record id="action_insurance_nominee_relation" model="ir.actions.act_window">
            <field name="name">Nominee Relations</field>
            <field name="res_model">insurance.nominee.relation</field>
            <field name="view_mode">list</field>
        </record>
    </data>
</odoo>