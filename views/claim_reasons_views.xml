<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="claim_reasons_form_view" model="ir.ui.view">
            <field name="name">claim.reasons.form.view</field>
            <field name="model">claim.reasons</field>
            <field name="arch" type="xml">
                <form edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="e.g. Third-party property or bodily damage.."
                                       required="1"/>
                            </group>
                            <group>
                                <field name="color" widget="color_picker"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="claim_reasons_list_view" model="ir.ui.view">
            <field name="name">claim.reasons.list.view</field>
            <field name="model">claim.reasons</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="color" widget="color_picker"/>
                </list>
            </field>
        </record>
        <record id="claim_reasons_search_view" model="ir.ui.view">
            <field name="name">claim.reasons.search.view</field>
            <field name="model">claim.reasons</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>
        <record id="action_claim_reasons" model="ir.actions.act_window">
            <field name="name">Claim Reasons</field>
            <field name="res_model">claim.reasons</field>
            <field name="view_mode">list,search</field>
        </record>
    </data>
</odoo>