<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="insured_document_type_form_view" model="ir.ui.view">
            <field name="name">insured.document.type.form.view</field>
            <field name="model">insured.document.type</field>
            <field name="arch" type="xml">
                <form edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="insured_document_type" required="1"/>
                            </group>
                            <group>
                                <field name="color" widget="color_picker"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="insured_document_type_list_view" model="ir.ui.view">
            <field name="name">insured.document.type.list.view</field>
            <field name="model">insured.document.type</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="insured_document_type"/>
                    <field name="color" widget="color_picker"/>
                </list>
            </field>
        </record>
        <record id="action_insured_document_type" model="ir.actions.act_window">
            <field name="name">Insured Documents</field>
            <field name="res_model">insured.document.type</field>
            <field name="view_mode">list</field>
        </record>
    </data>
</odoo>