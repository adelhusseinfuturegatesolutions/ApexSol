<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="fleet_features_form_view" model="ir.ui.view">
            <field name="name">fleet.features.form.view</field>
            <field name="model">fleet.features</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="e.g. Safety &amp; Driver‑Assistance"/>
                            </h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="fleet_features_list_view" model="ir.ui.view">
            <field name="name">fleet.features.list.view</field>
            <field name="model">fleet.features</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>
        <record id="action_fleet_features" model="ir.actions.act_window">
            <field name="name">Fleet Features</field>
            <field name="res_model">fleet.features</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
