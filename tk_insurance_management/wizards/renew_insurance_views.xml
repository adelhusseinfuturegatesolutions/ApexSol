<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="renew_insurance_form_view" model="ir.ui.view">
            <field name="name">renew.insurance.form.view</field>
            <field name="model">renew.insurance</field>
            <field name="arch" type="xml">
                <form>
                    <separator string="Insurance Details" name="insurance_details"/>
                    <group>
                        <group>
                            <field name="insurance_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="issue_date" required="1"/>
                        </group>
                    </group>
                    <separator string="Policy Holder Details" name="policy_holder_details"/>
                    <group>
                        <group>
                            <field name="policy_holder_id" readonly="1" force_save="1"/>
                            <field name="policy_holder_gender" readonly="1" force_save="1"/>
                            <label for="policy_holder_dob" string="Date of Birth"/>
                            <div class="address_format">
                                <field name="policy_holder_dob" style="width: 25%" readonly="1" force_save="1"/>
                                <strong style="margin-left: 15px;">&#160;Age</strong>
                                <field name="policy_holder_age" style="width: 25%; margin-left: 10px;"
                                       readonly="1" force_save="1"/>
                            </div>
                        </group>
                        <group>
                            <field name="email" readonly="1" force_save="1"/>
                            <field name="phone" readonly="1" force_save="1"/>
                            <span class="o_form_label o_td_label" name="address_name">
                                Address
                            </span>
                            <div class="o_address_format">
                                <field name="policy_holder_street" placeholder="Street" class="o_address_street"
                                       readonly="1" force_save="1"/>
                                <field name="policy_holder_street2" placeholder="Street 2" class="o_address_street"
                                       readonly="1" force_save="1"/>
                                <field name="policy_holder_city" placeholder="City" class="o_address_city" readonly="1"
                                       force_save="1"/>
                                <field name="policy_holder_state_id" class="o_address_state" placeholder="State"
                                       options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                       readonly="1" force_save="1"/>
                                <field name="policy_holder_zip" placeholder="ZIP" class="o_address_zip" readonly="1"
                                       force_save="1"/>
                                <field name="policy_holder_country_id" placeholder="Country" class="o_address_country"
                                       options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                                       readonly="1" force_save="1"/>
                            </div>
                        </group>
                    </group>
                    <separator string="Policy Details" name="policy_details"/>
                    <group>
                        <group>
                            <field name="insurance_category_id" readonly="1" force_save="1"/>
                            <field name="insurance_sub_category_id" readonly="1" force_save="1"/>
                            <field name="insurance_policy_id" readonly="1" force_save="1"/>
                            <field name="insurance_buying_for_id" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="policy_provider_cmp_id" readonly="1" force_save="1"/>
                            <field name="policy_certificate_no" required="category == 'vehicle'"
                                   invisible="category != 'vehicle'"/>
                            <field name="previous_policy_no" required="category == 'vehicle'"
                                   invisible="category != 'vehicle'"/>
                            <field name="policy_price_list_id" required="1"
                                   options="{'no_edit': True, 'no_create': True, 'no_open': True}"/>
                            <field name="policy_durations" invisible="1"/>
                            <field name="policy_amount"/>
                            <field name="claim_amount"/>
                            <field name="monthly_installment" invisible="1"/>
                            <field name="responsible_id" widget="many2one_avatar_user" readonly="1" force_save="1"/>
                            <field name="category" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <footer>
                        <button string="Insurance Renew" name="create_insurance_renew" type="object"
                                class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_renew_insurance" model="ir.actions.act_window">
            <field name="name">Renew Insurance</field>
            <field name="res_model">renew.insurance</field>
            <field name="target">new</field>
            <field name="view_id" ref="renew_insurance_form_view"/>
        </record>
    </data>
</odoo>