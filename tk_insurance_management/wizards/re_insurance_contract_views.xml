<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="re_insurance_contract_form_view" model="ir.ui.view">
            <field name="name">re.insurance.contract.form.view</field>
            <field name="model">re.insurance.contract</field>
            <field name="arch" type="xml">
                <form>
                    <separator name="contract_insurance_details" string="Insurance Details"/>
                    <group>
                        <group>
                            <field name="insurance_id" readonly="1"/>
                            <field name="insurance_policy_id" readonly="1"/>
                            <field name="policy_number" readonly="1"/>
                            <field name="policy_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="contract_date" readonly="1"/>
                            <field name="issue_date" readonly="1"/>
                            <field name="expiry_date" readonly="1"/>
                            <field name="sum_assured" readonly="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group name="contract_policy_provider_details" string="Policy Provider (Ceding Company)">
                            <field name="policy_provider_cmp_id" readonly="1"/>
                            <field name="provider_phone" widget="phone" readonly="1"/>
                            <field name="provider_email" widget="email" readonly="1"/>
                        </group>
                        <group name="contract_reinsurer_company_details" string="ReInsurer Company Details">
                            <field name="reinsurance_company_id" required="1"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="r_phone" widget="phone" required="1"/>
                            <field name="r_email" widget="email" required="1"/>
                            <field name="re_insurance_type_id" required="1"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="treaty_types" required="1"/>
                        </group>
                    </group>
                    <separator name="contract_financial_details" string="Financial Details"/>
                    <group>
                        <group>
                            <field name="retention_amount"/>
                            <field name="reinsured_amount"/>
                        </group>
                        <group>
                            <field name="reinsurance_premium"/>
                            <label for="reinsurer_percentage" string="Reinsurer Percentage"/>
                            <div class="address_format">
                                <field name="reinsurer_percentage" style="width: 30%"/>
                                <strong>&#160;%&#160;</strong>
                            </div>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <separator name="contract_coverage_details" string="Coverage Details"/>
                    <group>
                        <group>
                            <field name="territory" placeholder="e.g. UAE.."/>
                        </group>
                        <group>
                            <field name="start_date" required="1"/>
                            <field name="end_date" required="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                        </group>
                        <group name="contract_manager_details" string="Manager Details">
                            <field name="responsible_id" widget="many2one_avatar_user" required="1"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="contract_risk_description" string="Risk Descriptions">
                            <field name="risk_description" nolabel="1" placeholder="Risk Description.."/>
                        </page>
                        <page name="contract_exclusion" string="Exclusions">
                            <field name="exclusions" nolabel="1" placeholder="Exclusions.."/>
                        </page>
                        <page name="contract_terms_and_conditions" string="Terms &amp; Conditions">
                            <field name="terms_and_conditions" nolabel="1" placeholder="Terms &amp; Conditions.."/>
                        </page>
                    </notebook>
                    <footer>
                        <button string="Create" name="create_re_insurance" type="object" class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_re_insurance_contract" model="ir.actions.act_window">
            <field name="name">Create ReInsurance</field>
            <field name="res_model">re.insurance.contract</field>
            <field name="target">new</field>
            <field name="view_id" ref="re_insurance_contract_form_view"/>
        </record>
    </data>
</odoo>

