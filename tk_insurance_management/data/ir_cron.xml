<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <!--Insurance Auto Expire-->
        <record id="insurance_coverage_expiry_date" model="ir.cron">
            <field name="name">Insurance: Expire Running Insurance Policies</field>
            <field name="model_id" ref="tk_insurance_management.model_insurance_information"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_create_expired_policy()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--Insurance Renew-->
        <record id="insurance_policy_cancellation_notice" model="ir.cron">
            <field name="name">Insurance: Auto Cancel Expired Policies</field>
            <field name="model_id" ref="tk_insurance_management.model_insurance_information"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_create_cancellation_policy()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--Insurance Installment Invoice-->
        <record id="action_insurance_installment_invoice" model="ir.cron">
            <field name="name">Insurance: Insurance Installment Invoice</field>
            <field name="model_id" ref="tk_insurance_management.model_insurance_information"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_create_insurance_invoice()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--Re Insurance Auto Expire-->
        <record id="re_insurance_auto_expire_policy" model="ir.cron">
            <field name="name">ReInsurance: ReInsurance Auto Expire Policy</field>
            <field name="model_id" ref="tk_insurance_management.model_re_insurance"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_auto_expire_reinsurance_policies()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--Create Company to Partner-->
        <record id="action_scheduler_create_company_to_partner_rec" model="ir.cron">
            <field name="name">Insurance Company: Create Company to Partner</field>
            <field name="model_id" ref="tk_insurance_management.model_insurance_category"/>
            <field name="state" eval="'code'"/>
            <field name="code" eval="'model.action_scheduler_create_company_to_partner()'"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>