<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_tk_insurance_management" model="res.groups.privilege">
            <field name="name">Insurance</field>
            <field name="description">Access rights for Insurance Management</field>
        </record>
        <record id="insurance_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="module_tk_insurance_management"/>
        </record>
        <record id="insurance_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="implied_ids" eval="[(4, ref('insurance_user'))]"/>
            <field name="privilege_id" ref="module_tk_insurance_management"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="base.default_user_group" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('tk_insurance_management.insurance_manager'))]"/>
        </record>
    </data>
</odoo>