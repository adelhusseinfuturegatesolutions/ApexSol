<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <!--Insurance-->
        <!-- Insurance Manager-->
        <record id="manager_can_see_all_insurance_records" model="ir.rule">
            <field name="name">Insurance Manager: see all insurance records</field>
            <field name="model_id" ref="tk_insurance_management.model_insurance_information"/>
            <field name="domain_force">[(1,'=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <field name="groups" eval="[(4,ref('tk_insurance_management.insurance_manager'))]"/>
        </record>
        <!-- Insurance User-->
        <record id="users_can_only_see_their_own_insurance_records" model="ir.rule">
            <field name="name">Insurance User: own insurance records</field>
            <field name="model_id" ref="tk_insurance_management.model_insurance_information"/>
            <field name="domain_force">[('policy_holder_id','=',user.partner_id.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
            <field name="groups" eval="[(4,ref('tk_insurance_management.insurance_user'))]"/>
        </record>

        <!--Claim-->
        <!-- Claim Manager-->
        <record id="manager_can_see_all_claim_records" model="ir.rule">
            <field name="name">Insurance Manager: see all claim records</field>
            <field name="model_id" ref="tk_insurance_management.model_claim_information"/>
            <field name="domain_force">[(1,'=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <field name="groups" eval="[(4,ref('tk_insurance_management.insurance_manager'))]"/>
        </record>
        <!-- Claim User-->
        <record id="users_can_only_see_their_own_claim_records" model="ir.rule">
            <field name="name">Insurance User: own claim records</field>
            <field name="model_id" ref="tk_insurance_management.model_claim_information"/>
            <field name="domain_force">[('policy_holder_id','=',user.partner_id.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
            <field name="groups" eval="[(4,ref('tk_insurance_management.insurance_user'))]"/>
        </record>
    </data>
</odoo>