<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="insurance_time_period_form_view" model="ir.ui.view">
            <field name="name">insurance.time.period.form.view</field>
            <field name="model">insurance.time.period</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="t_period"/>
                            <h1>
                                <field name="t_period" placeholder="e.g. 12 Months" required="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="duration"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="insurance_time_period_list_view" model="ir.ui.view">
            <field name="name">insurance.time.period.list.view</field>
            <field name="model">insurance.time.period</field>
            <field name="arch" type="xml">
                <list>
                    <field name="t_period"/>
                    <field name="duration"/>
                </list>
            </field>
        </record>
        <record id="insurance_time_period_search_view" model="ir.ui.view">
            <field name="name">insurance.time.period.search.view</field>
            <field name="model">insurance.time.period</field>
            <field name="arch" type="xml">
                <search>
                    <field name="t_period"/>
                    <field name="duration"/>
                </search>
            </field>
        </record>
        <record id="action_insurance_time_period" model="ir.actions.act_window">
            <field name="name">Time Periods</field>
            <field name="res_model">insurance.time.period</field>
            <field name="view_mode">list,form,search</field>
        </record>
    </data>
</odoo>