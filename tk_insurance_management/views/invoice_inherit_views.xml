<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <!--Account Move-->
        <record id="account_move_form_view" model="ir.ui.view">
            <field name="name">account.move.form.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="insurance_information_id" invisible="insurance_information_id == False" readonly="1"/>
                    <field name="claim_information_id" invisible="claim_information_id == False" readonly="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
