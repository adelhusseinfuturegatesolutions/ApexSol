"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               Fecha de pago:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-esc=\"datetime.date.today() + relativedelta(days=object.reminder_days)\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Monto de la cuota:\n"
