"                        <t t-out=\"object.responsible_id.name\"></t>\n"
"                    </strong>\n"
"                </h5>\n"
"                <hr>\n"
"                <span>\n"
"                    <h4>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </h4>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.phone\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.email\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.website\"></t>\n"
"                </span>\n"
"            "
msgstr ""
"<p>\n"
"                    <h4>\n"
"                        Estimada,\n"
"                        <br>\n"
"                        <strong>\n"
"                            <t t-out=\"object.policy_holder_id.name\"></t>\n"
"                        </strong>\n"
"                    </h4>\n"
"                </p>\n"
"                <hr>\n"
"                <p>\n"
"                    Lamentamos informarle que su póliza de seguro con\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
