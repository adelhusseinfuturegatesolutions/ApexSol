#. module: tk_insurance_management
#: model:mail.template,body_html:tk_insurance_management.insurance_policy_approved_mail_template
msgid ""
"<table style=\"width: 100%\">\n"
"                    <tr>\n"
"                        <td>\n"
"                            Dear Customer,\n"
"                            <br>\n"
"                            <h4>\n"
"                                <strong>\n"
"                                    <t t-out=\"object.insured_id.name\"></t>\n"
"                                </strong>\n"
"                            </h4>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                    We hope this email finds you well. We are pleased to inform you that your insurance policy claim has\n"
"                    been approved. After careful evaluation of the provided information and necessary verifications, we\n"
"                    have determined that your claim meets the eligibility criteria outlined in your policy.\n"
"                </p>\n"
"                <p>\n"
"                    We understand the importance of a swift resolution, and we are committed to ensuring a seamless\n"
"                    claims process. Therefore, we would like to provide you with the following details regarding your\n"
"                    approved claim.\n"
"                </p>\n"
"                <hr>\n"
"                <table>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Claim Reference Number:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.claim_number\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy Number:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_id.insurance_number\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_policy_id.policy_name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy Category:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy Sub Category:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_sub_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Date of Approval:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.claim_date\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Approved Amount:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"format_amount(object.amount_paid, object.currency_id)\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                    Please review the details mentioned above and ensure their accuracy. If you have any concerns or\n"
"                    discrepancies, kindly contact our customer support team at\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.phone\"></t>\n"
"                    </strong>\n"
"                    or by replying to this email. Our representatives will be happy to assist you and address any\n"
"                    questions you may have.\n"
"                </p>\n"
"                <p>\n"
"                    The next steps of the claims process will depend on the nature of your specific claim. Our team will\n"
"                    be in touch with you shortly to discuss the further actions required. If there are any additional\n"
"                    documents or information needed, we will provide clear instructions on how to proceed.\n"
"                </p>\n"
"                <p>\n"
"                    Once again, congratulations on the approval of your insurance policy claim. We appreciate your\n"
"                    patience and cooperation throughout the evaluation process. Our priority is to provide you with the\n"
"                    support you need and ensure a smooth settlement of your claim.\n"
"                </p>\n"
"                <p>\n"
"                    Thank you for choosing\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
"                    as your insurance provider. We value your trust and confidence in our services, and we remain\n"
"                    committed to delivering exceptional customer experience.\n"
"                </p>\n"
"                <h6>\n"
"                    Sincerely,\n"
"                </h6>\n"
"                <h5>\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.name\"></t>\n"
"                    </strong>\n"
"                </h5>\n"
"                <hr>\n"
"                <span>\n"
"                    <h6>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </h6>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.phone\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.email\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.website\"></t>\n"
"                </span>\n"
"            "
msgstr ""
"<table style=\"width: 100%\">\n"
"                    <tr>\n"
"                        <td>\n"
"                            عزيزي العميل،\n"
"                            <br>\n"
"                            <h4>\n"
"                                <strong>\n"
"                                    <t t-out=\"object.insured_id.name\"></t>\n"
"                                </strong>\n"
"                            </h4>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                   نأمل أن تصلك هذه الرسالة الإلكترونية بحالة جيدة. يسعدنا أن نعلمك أن مطالبتك ببوليصة التأمين قد تم قبولها\n"
"                    تمت الموافقة. بعد التقييم الدقيق للمعلومات المقدمة والتحققات اللازمة، قمنا\n"
"                   قررت أن مطالبتك تفي بمعايير الأهلية الموضحة في سياستك.\n"
"                </p>\n"
"                <p>\n"
"                    نحن ندرك أهمية التوصل إلى حل سريع، ونحن ملتزمون بضمان التوصل إلى حل سلس\n"
"                    عملية المطالبات. لذلك، نود أن نقدم لك التفاصيل التالية المتعلقة بك\n"
"                   المطالبة المعتمدة.\n"
"                </p>\n"
"                <hr>\n"
"                <table>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                الرقم المرجعي للمطالبة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.claim_number\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               رقم مركز الشرطه:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_id.insurance_number\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               سياسة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_policy_id.policy_name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               فئة السياسة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               الفئة الفرعية للسياسة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_sub_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               تاريخ الموافقة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.claim_date\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               المبلغ المعتمد:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"format_amount(object.amount_paid, object.currency_id)\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                   يرجى مراجعة التفاصيل المذكورة أعلاه والتأكد من دقتها. إذا كان لديك أي مخاوف أو\n"
"                   التناقضات، يرجى الاتصال بفريق دعم العملاء لدينا على\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.phone\"></t>\n"
"                    </strong>\n"
"                    أو عن طريق الرد على هذا البريد الإلكتروني. سيكون ممثلونا سعداء بمساعدتك ومعالجة أي مشكلة\n"
"                    الأسئلة التي قد تكون لديكم.\n"
"                </p>\n"
"                <p>\n"
"                    ستعتمد الخطوات التالية لعملية المطالبات على طبيعة مطالبتك المحددة. فريقنا سوف\n"
"                    سنتواصل معك قريبًا لمناقشة الإجراءات الإضافية المطلوبة. إذا كان هناك أي إضافية\n"
"                    المستندات أو المعلومات المطلوبة، سنقدم تعليمات واضحة حول كيفية المتابعة.\n"
"                </p>\n"
"                <p>\n"
"                    مرة أخرى، تهانينا على الموافقة على مطالبتك ببوليصة التأمين. نحن نقدر الخاص بك\n"
"                    الصبر والتعاون طوال عملية التقييم. أولويتنا هي أن نقدم لك\n"
"                   الدعم الذي تحتاجه وضمان تسوية سلسة لمطالبتك.\n"
"                </p>\n"
"                <p>\n"
"                    شكرا لاختيارك\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
"                    كمزود التأمين الخاص بك. نحن نقدر ثقتكم وثقتكم في خدماتنا، وسنظل كذلك\n"
"                   ملتزمون بتقديم تجربة استثنائية للعملاء.\n"
"                </p>\n"
"                <h6>\n"
"                  بإخلاص،\n"
"                </h6>\n"
"                <h5>\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.name\"></t>\n"
"                    </strong>\n"
"                </h5>\n"
"                <hr>\n"
"                <span>\n"
"                    <h6>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </h6>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.phone\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.email\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.website\"></t>\n"
"                </span>\n"
"            "

#. module: tk_insurance_management
#: model:mail.template,body_html:tk_insurance_management.insurance_policy_has_expired_mail_template
msgid ""
"<table style=\"width: 100%\">\n"
"                    <tr>\n"
"                        <td>\n"
"                            Dear Customer,\n"
"                            <br>\n"
"                            <h4>\n"
"                                <strong>\n"
"                                    <t t-out=\"object.insured_id.name\"></t>\n"
"                                </strong>\n"
"                            </h4>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                    We hope this email finds you well. We are writing to provide you with important information related\n"
"                    to your insurance policy with\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
"                </p>\n"
"                <p>\n"
"                    We want to keep you informed about the status of your insurance policy and ensure that you have all\n"
"                    the necessary details readily available. Our records indicate that there have been recent updates or\n"
"                    changes pertaining to your policy.\n"
"                </p>\n"
"                <hr>\n"
"                <table>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Please find below the key details related to your insurance policy:\n"
"                            </strong>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy Number:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_number\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_policy_id.policy_name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy Category:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Policy Sub Category:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_sub_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Coverage Start Date:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.issue_date\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Coverage End Date:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.expiry_date\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                Premium Amount:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"format_amount(object.total_policy_amount, object.currency_id)\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                    It is crucial to review the above information carefully to ensure its accuracy. If you have any\n"
"                    questions or concerns regarding the policy details, please reach out to our dedicated customer\n"
"                    support team at\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.phone\"></t>\n"
"                    </strong>\n"
"                    or reply to this email. Our team will be happy to assist you.\n"
"                </p>\n"
"                <p>\n"
"                    We strive to provide you with comprehensive coverage and exceptional service. Should you require any\n"
"                    updates or modifications to your policy, please inform us at your earliest convenience. We will\n"
"                    work diligently to accommodate your requests and ensure that your insurance policy aligns with your\n"
"                    evolving needs.\n"
"                </p>\n"
"                <p>\n"
"                    At\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
"                    we value your trust and are committed to your satisfaction. We appreciate your continued support\n"
"                    and look forward to serving you as your trusted insurance provider.\n"
"                </p>\n"
"                <p>\n"
"                    Thank you for your attention to this matter.\n"
"                </p>\n"
"                <h6>\n"
"                    Sincerely,\n"
"                </h6>\n"
"                <h5>\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.name\"></t>\n"
"                    </strong>\n"
"                </h5>\n"
"                <hr>\n"
"                <span>\n"
"                    <h6>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </h6>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.phone\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.email\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.website\"></t>\n"
"                </span>\n"
"            "
msgstr ""
"<table style=\"width: 100%\">\n"
"                    <tr>\n"
"                        <td>\n"
"                           عزيزي العميل،\n"
"                            <br>\n"
"                            <h4>\n"
"                                <strong>\n"
"                                    <t t-out=\"object.insured_id.name\"></t>\n"
"                                </strong>\n"
"                            </h4>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                    نأمل أن تصلك هذه الرسالة الإلكترونية بحالة جيدة. نكتب إليك لتزويدك بالمعلومات المهمة ذات الصلة\n"
"                   إلى بوليصة التأمين الخاصة بك مع\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
"                </p>\n"
"                <p>\n"
"                   نريد أن نبقيك على علم بحالة بوليصة التأمين الخاصة بك والتأكد من حصولك على كل شيء\n"
"                    التفاصيل الضرورية متاحة بسهولة. تشير سجلاتنا إلى وجود تحديثات حديثة أو\n"
"                   التغييرات المتعلقة بسياستك.\n"
"                </p>\n"
"                <hr>\n"
"                <table>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                يرجى الاطلاع أدناه على التفاصيل الرئيسية المتعلقة ببوليصة التأمين الخاصة بك:\n"
"                            </strong>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                              رقم مركز الشرطه:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_number\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                               سياسة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_policy_id.policy_name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                فئة السياسة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                الفئة الفرعية للسياسة:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.insurance_sub_category_id.name\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                تاريخ بدء التغطية:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.issue_date\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                تاريخ انتهاء التغطية:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"object.expiry_date\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                    <tr>\n"
"                        <td>\n"
"                            <strong>\n"
"                                مبلغ القسط:\n"
"                            </strong>\n"
"                        </td>\n"
"                        <td>\n"
"                            <t t-out=\"format_amount(object.total_policy_amount, object.currency_id)\"></t>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"                <hr>\n"
"                <p>\n"
"                    ومن الضروري مراجعة المعلومات المذكورة أعلاه بعناية للتأكد من دقتها. إذا كان لديك أي\n"
"                    إذا كانت لديك أسئلة أو استفسارات بخصوص تفاصيل السياسة، فيرجى التواصل مع عملائنا المتفانين\n"
"                   فريق الدعم في\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.phone\"></t>\n"
"                    </strong>\n"
"                    أو الرد على هذا البريد الإلكتروني. سيكون فريقنا سعيدًا بمساعدتك.\n"
"                </p>\n"
"                <p>\n"
"                    نحن نسعى جاهدين لنقدم لك تغطية شاملة وخدمة استثنائية. إذا كنت تحتاج إلى أي\n"
"                   التحديثات أو التعديلات على سياستك، يرجى إبلاغنا في أقرب وقت ممكن. ونحن سوف\n"
"                    العمل بجد لتلبية طلباتك والتأكد من أن بوليصة التأمين الخاصة بك تتماشى مع متطلباتك\n"
"                    الاحتياجات المتطورة.\n"
"                </p>\n"
"                <p>\n"
"                    في\n"
"                    <strong>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </strong>\n"
"                    نحن نقدر ثقتك ونلتزم بإرضائك. نحن نشكرك على دعمك المستمر\n"
"                    ونتطلع إلى خدمتك كمزود تأمين موثوق به.\n"
"                </p>\n"
"                <p>\n"
"                    شكرا لاهتمامكم بهذه المسألة.\n"
"                </p>\n"
"                <h6>\n"
"                    بإخلاص،\n"
"                </h6>\n"
"                <h5>\n"
"                    <strong>\n"
"                        <t t-out=\"object.agent_id.name\"></t>\n"
"                    </strong>\n"
"                </h5>\n"
"                <hr>\n"
"                <span>\n"
"                    <h6>\n"
"                        <t t-out=\"object.policy_provider_cmp_id.name\"></t>\n"
"                    </h6>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.phone\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.email\"></t>\n"
"                    <br>\n"
"                    <t t-out=\"object.policy_provider_cmp_id.website\"></t>\n"
"                </span>\n"
"            "

