<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="0">
        <record id="vehicle_rental_booking_enquiry_mail_template" model="mail.template">
            <field name="name">Vehicle Rental Booking Enquiry Mail Template</field>
            <field name="model_id" ref="vehicle_rental.model_crm_lead"/>
            <field name="subject">New Rental Booking Enquiry Received – {{ object.contact_name}}</field>
            <field name="email_from">{{object.company_id.email}}</field>
            <field name="partner_to">{{object.team_id.id}}</field>
            <field name="body_html" type="html">
                <h4>
                    Dear
                    <strong>
                        <t t-out="object.team_id.name"/>
                    </strong>
                    ,
                </h4>
                <hr style="margin: 0; padding: 0;"/>
                <p>
                    A new rental booking enquiry has been received from the website and has been successfully created as
                    a CRM Lead.
                </p>
                <hr style="margin: 0; padding: 0;"/>
                <span>
                    <strong>
                        Enquiry Details
                    </strong>
                </span>
                <hr style="margin: 0; padding: 0;"/>
                <table class="table table-bordered" style="width:100%; border-collapse:collapse;">
                    <tr>
                        <td style="width: 35%; padding: 5px;">
                            <strong>Customer Name</strong>
                        </td>
                        <td style="width: 65%; padding: 5px;">
                            <span t-field="object.contact_name"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 35%; padding: 5px;">
                            <strong>Contact Number</strong>
                        </td>
                        <td style="width: 65%; padding: 5px;">
                            <span t-field="object.phone"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 35%; padding: 5px;">
                            <strong>Email</strong>
                        </td>
                        <td style="width: 65%; padding: 5px;">
                            <span t-field="object.email_from"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 35%; padding: 5px;">
                            <strong>Vehicle</strong>
                        </td>
                        <td style="width: 65%; padding: 5px;">
                            <span t-esc="object.vehicle_id.name"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 35%; padding: 5px;">
                            <strong>Start Date</strong>
                        </td>
                        <td style="width: 65%; padding: 5px;">
                            <span t-esc="object.env.context.get('start_date')"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 35%; padding: 5px;">
                            <strong>End Date</strong>
                        </td>
                        <td style="width: 65%; padding: 5px;">
                            <span t-esc="object.env.context.get('end_date')"/>
                        </td>
                    </tr>
                </table>
                <hr style="margin: 5px;"/>
                <p>
                    Please review the lead in the system and follow up with the customer at the earliest to
                    proceed with availability confirmation and quotation.
                </p>
                <hr style="margin: 0; padding: 0;"/>
                <span>
                    <strong>
                        Best regards,
                        <br/>
                        <t t-out="object.user_id.name"/>
                    </strong>
                    <br/>
                    <t t-out="object.company_id.name"/>
                    <br/>
                    <t t-out="object.company_id.phone"/>
                    <br/>
                    <t t-out="object.company_id.email"/>
                    <br/>
                    <t t-out="object.company_id.website"/>
                </span>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>