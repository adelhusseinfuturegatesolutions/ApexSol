            <field name="model_id" ref="vehicle_rental.model_maintenance_schedule"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="vehicle_rental_company_restricted_vehicle_scratch_report" model="ir.rule">
            <field name="name">Vehicle Rental : Only Company Vehicle Scratch Report</field>
            <field name="model_id" ref="vehicle_rental.model_vehicle_scratch_report"/>
