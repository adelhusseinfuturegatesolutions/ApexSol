<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="vehicle_rental_company_restricted_vehicle_contract" model="ir.rule">
            <field name="name">Vehicle Rental : Only Company Vehicle Contracts</field>
            <field name="model_id" ref="vehicle_rental.model_vehicle_contract"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="vehicle_rental_company_restricted_cancellation_policy" model="ir.rule">
