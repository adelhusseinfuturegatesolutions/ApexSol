<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="insurance_expiry_report_form_view" model="ir.ui.view">
            <field name="name">insurance.expiry.report.form.view</field>
            <field name="model">insurance.expiry.report</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="start_date" required="1"/>
                        </group>
                        <group>
                            <field name="end_date" required="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_insurance_expiry_excel" type="object" string="Generate Report"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_insurance_expiry_report" model="ir.actions.act_window">
            <field name="name">Upcoming Insurance Expiration Report</field>
            <field name="res_model">insurance.expiry.report</field>
            <field name="target">new</field>
            <field name="view_id" ref="insurance_expiry_report_form_view"/>
        </record>
    </data>
</odoo>
