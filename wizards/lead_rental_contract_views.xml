<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="lead_rental_contract_form_view" model="ir.ui.view">
            <field name="name">lead.rental.contract.form.view</field>
            <field name="model">lead.rental.contract</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="crm_lead_id" readonly="1"/>
                            <field name="partner_id" required="1" options="{'no_quick_create': True}"/>
                            <field name="vehicle_id" required="1" options="{'no_quick_create': True}"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Create Contract" name="action_create_rental_contract" type="object"
                                class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_lead_rental_contract" model="ir.actions.act_window">
            <field name="name">Create Contract</field>
            <field name="res_model">lead.rental.contract</field>
            <field name="target">new</field>
            <field name="view_id" ref="lead_rental_contract_form_view"/>
        </record>
    </data>
</odoo>